{
  "name": "oss-license-analyzer",
  "version": "1.0.0",
  "description": "OSS License Analyzer - Node.js Migration from Spring Boot",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "stop": "lsof -ti:8080 | xargs kill -9 || echo 'No process on port 8080'",
    "restart": "npm run stop && sleep 2 && npm start",
    "status": "lsof -i:8080 || echo 'Port 8080 is free'"
  },
  "keywords": [
    "oss",
    "license",
    "analyzer",
    "compliance",
    "spdx",
    "ort"
  ],
  "author": "Srivatssan",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sequelize": "^6.35.0",
    "sqlite3": "^5.1.6",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "axios": "^1.6.0",
    "winston": "^3.11.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.1",
    "fastest-levenshtein": "^1.0.16"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
