# Server Configuration
PORT=8080
NODE_ENV=development

# Database
DATABASE_PATH=./data/paacdb.sqlite

# GitHub API
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Policy Configuration (comma-separated)
APPROVED_LICENSES=MIT,Apache-2.0,BSD-2-Clause,BSD-3-Clause,ISC,EPL-2.0,MPL-2.0,LGPL-2.1-only,LGPL-3.0-only,GPL-2.0-only,GPL-3.0-only,CC0-1.0
DENIED_LICENSES=SSPL-1.0,BSL-1.1,RPL-1.5,JSON,NonStandardLicense,Commercial

# Docker Configuration
DOCKER_IMAGE=ghcr.io/oss-review-toolkit/ort:latest
DOCKER_WORKSPACE=/workspace
ANALYZER_WORK_DIR=/tmp/oss-analyzer

# Security
SHUTDOWN_API_KEY=dummy-key

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
